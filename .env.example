# API Key de Gemini (obtenla en https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=TU_API_KEY_AQUI

# ID del Google Spreadsheet (la parte de la URL entre /d/ y /edit)
# Ejemplo: https://docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit
SPREADSHEET_ID=TU_SPREADSHEET_ID_AQUI

# Ruta al archivo JSON de la cuenta de servicio de Google Cloud
# (descárgalo desde IAM & Admin > Service Accounts > Keys)
GOOGLE_SERVICE_ACCOUNT_FILE=service-account.json

# Puerto del servidor (opcional, por defecto 3000)
PORT=3000
